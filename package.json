{
  "name": "@firekid/hurl",
  "version": "1.0.3",
  "description": "Zero-dependency HTTP client for Node.js and edge runtimes. Built on fetch. The modern replacement for axios, request, got, node-fetch, and ky. Works on Cloudflare Workers, Vercel Edge, Deno, and Bun.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "http",
    "https",
    "fetch",
    "fetch-wrapper",
    "fetch-api",
    "axios",
    "axios-alternative",
    "axios-replacement",
    "axios-wrapper",
    "request",
    "request-replacement",
    "request-deprecated",
    "got",
    "got-alternative",
    "ky",
    "ky-alternative",
    "node-fetch",
    "node-fetch-alternative",
    "wretch",
    "superagent",
    "http-client",
    "http-request",
    "https-client",
    "rest-client",
    "api-client",
    "node",
    "nodejs",
    "node-http",
    "typescript",
    "typescript-http",
    "edge-runtime",
    "edge-function",
    "cloudflare-workers",
    "cloudflare",
    "vercel-edge",
    "vercel",
    "deno",
    "bun",
    "zero-dependencies",
    "zero-deps",
    "no-dependencies",
    "interceptors",
    "request-interceptor",
    "response-interceptor",
    "retry",
    "auto-retry",
    "exponential-backoff",
    "timeout",
    "abort",
    "abort-controller",
    "auth",
    "bearer-token",
    "basic-auth",
    "api-key",
    "proxy",
    "socks5",
    "http-proxy",
    "cache",
    "request-cache",
    "deduplication",
    "request-dedup",
    "upload-progress",
    "download-progress",
    "file-upload",
    "multipart",
    "stream",
    "json",
    "json-parser",
    "modern",
    "lightweight",
    "minimal",
    "promise",
    "async-await"
  ],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "@types/node": "^20.0.0"
  }
}